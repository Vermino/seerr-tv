<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/seerr_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="48dp"
            android:paddingVertical="40dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="36dp">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="20dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/banner" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/setup_title"
                    android:textColor="@color/seerr_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="420dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/setup_subtitle"
                    android:textColor="@color/seerr_text_dim"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/url_input"
                    android:layout_width="460dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/edit_bg"
                    android:hint="@string/setup_hint"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:nextFocusDown="@+id/connect_button"
                    android:padding="16dp"
                    android:textColor="@color/seerr_text"
                    android:textColorHint="@color/seerr_text_dim"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="460dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:text="@string/setup_helper"
                    android:textColor="@color/seerr_text_dim"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/connect_button"
                    android:layout_width="460dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/btn_bg"
                    android:nextFocusUp="@+id/url_input"
                    android:padding="16dp"
                    android:text="@string/setup_connect"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
